{
  "name": "amnesic-browser",
  "version": "0.6.0",
  "private": true,
  "description": "A tabbed desktop browser engineered to leave nothing recoverable on disk after the process exits.",
  "license": "Apache-2.0",
  "author": {
    "name": "OttoDev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Otto-Deviant1904/Amnesic.git"
  },
  "main": "out/main/index.js",
  "desktopName": "amnesic.desktop",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "verify:footprint": "bash scripts/verify_footprint.sh",
    "update:blocklists": "node scripts/update-blocklists.mjs",
    "predist": "node node_modules/electron/install.js",
    "dist": "electron-vite build && electron-builder --linux --publish never",
    "prepare": "husky"
  },
  "dependencies": {
    "@ghostery/adblocker": "2.18.1",
    "@ghostery/adblocker-electron": "2.18.1",
    "@ghostery/adblocker-electron-preload": "2.18.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.8",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "7.3.6",
    "vitest": "4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,js,json,md}": [
      "prettier --write"
    ]
  }
}
