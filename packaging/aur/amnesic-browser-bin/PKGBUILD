# Maintainer: OttoDev
pkgname=amnesic-browser-bin
pkgver=0.1.2
pkgrel=1
pkgdesc="A tabbed desktop browser engineered to leave nothing recoverable on disk after the process exits"
arch=('x86_64')
url="https://github.com/Otto-Deviant1904/Amnesic"
license=('Apache-2.0')
depends=('gtk3' 'nss' 'alsa-lib' 'libxss' 'libxtst' 'at-spi2-core')
optdepends=('fuse2: run the AppImage directly without --appimage-extract-and-run')
provides=('amnesic-browser')
conflicts=('amnesic-browser')
options=('!strip')
source=(
  "$pkgname-$pkgver.AppImage::$url/releases/download/v$pkgver/amnesic-browser-$pkgver-x86_64.AppImage"
  "LICENSE-$pkgver::$url/raw/v$pkgver/LICENSE"
)
sha256sums=(
  '527096b4b44426b66f1319431fd7193fb36075fd032d161e209166fa8c744b19'
  'c71d239df91726fc519c6eb72d318ec65820627232b2f796219e87dcf35d0ab4'
)

package() {
  install -Dm755 "$pkgname-$pkgver.AppImage" "$pkgdir/opt/$pkgname/amnesic-browser.AppImage"

  # Icon and .desktop file are bundled inside the AppImage's own squashfs
  # image rather than shipped as separate PKGBUILD sources, so they can
  # never drift out of sync with the release they're extracted from.
  "$pkgdir/opt/$pkgname/amnesic-browser.AppImage" --appimage-extract >/dev/null

  install -Dm644 squashfs-root/usr/share/icons/hicolor/128x128/apps/amnesic.png \
    "$pkgdir/usr/share/icons/hicolor/128x128/apps/amnesic.png"
  install -Dm644 squashfs-root/usr/share/icons/hicolor/256x256/apps/amnesic.png \
    "$pkgdir/usr/share/icons/hicolor/256x256/apps/amnesic.png"
  install -Dm644 squashfs-root/usr/share/icons/hicolor/512x512/apps/amnesic.png \
    "$pkgdir/usr/share/icons/hicolor/512x512/apps/amnesic.png"

  # The bundled .desktop file's Exec=AppRun %U only resolves inside the
  # AppImage's own mount; repoint it at the installed, real path.
  sed "s|^Exec=AppRun|Exec=/opt/$pkgname/amnesic-browser.AppImage|" \
    squashfs-root/amnesic.desktop > amnesic-browser.desktop
  install -Dm644 amnesic-browser.desktop "$pkgdir/usr/share/applications/amnesic-browser.desktop"

  cat > amnesic-browser-wrapper <<'EOF'
#!/bin/sh
exec /opt/amnesic-browser-bin/amnesic-browser.AppImage "$@"
EOF
  install -Dm755 amnesic-browser-wrapper "$pkgdir/usr/bin/amnesic-browser"

  install -Dm644 "LICENSE-$pkgver" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
